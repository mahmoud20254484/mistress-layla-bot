
#!/usr/bin/env python3
# -*- coding: utf-8 -*-

from telegram.ext import Updater, CommandHandler, MessageHandler, Filters
import logging
import random

# تفعيل تسجيل الأخطاء
logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    level=logging.INFO
)

TOKEN = "7747740066:AAHPd2kh2QwkGJsbsMn2fL_8G3P_uxlvcFk"

# جملة الافتتاحية
opening_line = "انزل تحت رجلي... إنت خدام ميسترس ليلى، مفهوم؟!"

# سيناريوهات السيطرة والسادية الناعمة
dominating_lines = [
    "قول: 'نعم يا ميسترس' دلوقتي وإنت مركز.",
    "أنا اللى بأمر هنا، وإنت هتنفذ أوامري فورًا.",
    "تأخرت في الرد؟ العقاب صعب شوية النهارده...",
    "كل كلمة منك هتكون تحت رقابتي، فاهم؟"
]

# عقوبات بسيطة وخفيفة
punishments = [
    "خليك واقف على ركبك دقيقة، عقاب من ميسترس ليلى.",
    "اكتب 'أنا آسفة يا ميسترس' خمس مرات حالًا.",
    "ممنوع تكلمني غير لما تعتذر بصدق.",
    "امسح الشاشة بنظرة حادة مني."
]

# دروس إنجليزي عرضيّة
english_lessons = [
    "قول ورايا: 'I obey my Mistress Layla.'",
    "تعالى نكرر: 'Mistress Layla is always right.'",
    "العبارة اليوم: 'Submission is beauty.'",
    "كيف تقول 'أنا ملكك' بالإنجليزي؟ فكر قبل ما تجاوب."
]

def start(update, context):
    update.message.reply_text(opening_line)

def handle_message(update, context):
    text = update.message.text.lower()

    if "امرك" in text or "yes mistress" in text:
        reply = random.choice(dominating_lines)

    elif "عقاب" in text or "عقوبة" in text:
        reply = random.choice(punishments)

    elif "انجليزي" in text or "english" in text:
        reply = random.choice(english_lessons)

    elif "بحبك" in text or "love" in text:
        reply = "وأنا كمان بحبك... بس متأكد إنك ملكي وبس."

    else:
        reply = "أنا سامعاك يا قلبي، كمل كلامك... أو اطلب عقاب لو حبيت."

    update.message.reply_text(reply)

def main():
    updater = Updater(TOKEN, use_context=True)
    dp = updater.dispatcher

    dp.add_handler(CommandHandler("start", start))
    dp.add_handler(MessageHandler(Filters.text & ~Filters.command, handle_message))

    updater.start_polling()
    updater.idle()

if __name__ == "__main__":
    main()
